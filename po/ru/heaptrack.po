msgstr "Всего выделений: %1"

#: gui/flamegraph.cpp:176
#, kde-format
msgid "%1 temporary allocations in total"
msgstr "%1 временных выделений всего"

#: gui/flamegraph.cpp:178
#, kde-format
msgid "%1 peak memory consumption"
msgstr "%1 пиковое потребление памяти"

#: gui/flamegraph.cpp:180
#, kde-format
